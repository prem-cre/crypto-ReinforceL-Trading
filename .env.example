# ─── App ─────────────────────────────────────────────────────
APP_ENV=development
API_V1_PREFIX=/api
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Database (Neon Postgres) ─────────────────────────────────
# Get from https://console.neon.tech → your project → Connection Details → Pooled connection
# Format:   postgresql+asyncpg://USER:PASS@ep-xxx.region.aws.neon.tech/DBNAME?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cryptobot
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/cryptobot

# ─── Auth ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-strong-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Model registry (HuggingFace Hub) ─────────────────────────
# Token: https://huggingface.co/settings/tokens   (Read+Write)
# Repo : create at https://huggingface.co/new   →   "yourname/crypto-rl-bot"
HF_TOKEN=
HF_MODEL_REPO=

# ─── LLM (Google Gemini — free tier) ──────────────────────────
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Experiment tracking (Weights & Biases) ───────────────────
# https://wandb.ai/authorize
WANDB_API_KEY=
WANDB_PROJECT=crypto-rl-trading-bot

# ─── Exchange (Binance — public endpoints work without keys) ──
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ─── Trading config ───────────────────────────────────────────
TRADING_PAIRS=BTC/USDT,ETH/USDT,BNB/USDT
TIMEFRAME=1h
INITIAL_CAPITAL=10000

# ─── RL hyperparameters ───────────────────────────────────────
STATE_SIZE=10
LEARNING_RATE=0.001
GAMMA=0.99
BATCH_SIZE=64
EPOCHS=10

# ─── Risk ─────────────────────────────────────────────────────
MAX_RISK_PER_TRADE=0.02
MAX_LEVERAGE=10
MAX_OPEN_POSITIONS=5
STOP_LOSS_DISTANCE=0.02
TAKE_PROFIT_DISTANCE=0.04

# ─── Frontend (Vite) ──────────────────────────────────────────
# In Vercel: set this to your HF Space URL, e.g. https://yourname-crypto-rl-bot.hf.space
VITE_API_URL=http://localhost:8000
